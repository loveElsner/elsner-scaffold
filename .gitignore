# =============================================================================
# Elsner Scaffold — .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Node / npm
# -----------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.yarn/
.pnpm-debug.log*
package-lock.json
yarn.lock
pnpm-lock.yaml

# -----------------------------------------------------------------------------
# Build output (compiled assets — generated by `npm run build`)
# -----------------------------------------------------------------------------
assets/dist/css/
assets/dist/js/

# Source maps
assets/dist/**/*.map
assets/src/**/*.map

# -----------------------------------------------------------------------------
# OS & editor artifacts
# -----------------------------------------------------------------------------

# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Icon?
ehthumbs.db
Thumbs.db

# Windows
desktop.ini
$RECYCLE.BIN/

# Linux
*~

# VS Code
.vscode/
*.code-workspace

# JetBrains (PhpStorm, WebStorm, etc.)
.idea/
*.iml
*.iws
*.ipr

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim / Neovim
*.swp
*.swo
*.swn
[._]*.s[a-v][a-z]
[._]*.sw[a-p]
Session.vim
.netrwhist

# Emacs
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc
auto-save-list
tramp

# -----------------------------------------------------------------------------
# Environment & secrets
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
*.local
config.local.php
wp-config.php

# -----------------------------------------------------------------------------
# Logs & temp files
# -----------------------------------------------------------------------------
*.log
*.logs
logs/
tmp/
temp/
.tmp/
.cache/

# -----------------------------------------------------------------------------
# ACF JSON (optional — comment out if you want to track field group JSON)
# Keeping JSON tracked is recommended for team workflows / version control.
# Uncomment the line below only if you prefer not to track ACF field groups.
# -----------------------------------------------------------------------------
# inc/acf/json/*.json

# -----------------------------------------------------------------------------
# WordPress generated / uploaded content (should not live in theme repo)
# -----------------------------------------------------------------------------
uploads/
*.sql
*.sql.gz
*.zip
*.tar.gz
*.tar
*.rar

# -----------------------------------------------------------------------------
# PHP / Composer
# -----------------------------------------------------------------------------
vendor/
composer.lock

# -----------------------------------------------------------------------------
# Test / coverage reports
# -----------------------------------------------------------------------------
coverage/
.nyc_output/
test-results/
*.lcov

# -----------------------------------------------------------------------------
# Sass cache (if ever added alongside PostCSS)
# -----------------------------------------------------------------------------
.sass-cache/
*.css.map

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
*.bak
*.orig
*.patch
.phpunit.result.cache
phpunit.xml
.phpcs.xml
