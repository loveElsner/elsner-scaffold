{
  "name": "elsner-scaffold",
  "version": "1.0.0",
  "description": "Elsner Scaffold WordPress theme — PostCSS + Webpack build pipeline",
  "private": true,
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "build": "npm run build:css && npm run build:js",
    "dev": "npm run dev:css & npm run dev:js",
    "dev:css": "postcss assets/src/css/main.pcss -o assets/dist/css/main.css --watch",
    "dev:js": "webpack --mode development --watch",
    "build:css": "postcss assets/src/css/main.pcss -o assets/dist/css/main.css --env production",
    "build:js": "webpack --mode production",
    "build:editor": "postcss assets/src/css/editor.pcss -o assets/dist/css/editor.css --env production",
    "build:print": "postcss assets/src/css/print.pcss -o assets/dist/css/print.css --env production",
    "build:admin": "postcss assets/src/css/admin.pcss -o assets/dist/css/admin.css --env production",
    "lint:css": "stylelint \"assets/src/css/**/*.pcss\"",
    "lint:js": "eslint assets/src/js",
    "lint": "npm run lint:css && npm run lint:js"
  },
  "dependencies": {},
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "autoprefixer": "^10.4.19",
    "babel-loader": "^9.1.3",
    "browserslist": "^4.23.0",
    "css-loader": "^6.11.0",
    "cssnano": "^7.0.1",
    "eslint": "^8.57.0",
    "mini-css-extract-plugin": "^2.9.0",
    "postcss": "^8.4.38",
    "postcss-cli": "^11.0.0",
    "postcss-import": "^16.1.0",
    "postcss-nested": "^6.0.1",
    "postcss-preset-env": "^9.5.4",
    "stylelint": "^16.5.0",
    "stylelint-config-standard": "^36.0.0",
    "webpack": "^5.91.0",
    "webpack-cli": "^5.1.4"
  },
  "browserslist": [
    "> 0.5%",
    "last 2 major versions",
    "not dead",
    "not op_mini all"
  ]
}
